# Data Platform - API Dockerfile
FROM python:3.14-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir fastapi uvicorn sqlalchemy psycopg2-binary pyyaml

# Copy app files
COPY api /app/api
COPY config /app/config
COPY utils /app/utils

# Expose port
EXPOSE 8000

# Run API
CMD ["python", "-m", "uvicorn", "api.app:app", "--host", "0.0.0.0", "--port", "8000"]